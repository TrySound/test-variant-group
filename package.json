    "build-storybook": "storybook build"
  },
  "dependencies": {
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router": "^7.15.0",
    "vite": "^8.0.10"
  },
  "devDependencies": {
    "@storybook/react": "^10.3.6",
    "@storybook/react-vite": "^10.3.6",
    "@types/node": "^25.6.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "concurrently": "^9.2.1",
    "prettier": "^3.8.3",
    "storybook": "^10.3.6",
    "typescript": "^6.0.3"
  }
}
