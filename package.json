  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": "24"
  },
  "type": "module",
  "scripts": {
    "format": "prettier --write .",
    "check": "tsc",
    "dev": "concurrently \"pnpm dev:api\" \"pnpm dev:client\"",
